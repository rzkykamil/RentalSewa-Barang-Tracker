// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  RENTER
  ADMIN
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(160)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole
  phone        String?  @db.VarChar(30)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  items            Item[]
  bookingsAsRenter Booking[]

  @@map("users")
}

enum ItemCondition {
  BAIK
  CUKUP
  RUSAK_RINGAN
}

enum ItemStatus {
  TERSEDIA
  DISEWA
  TELAT_KEMBALI
  NONAKTIF
}

model Item {
  id           String        @id @default(uuid()) @db.Uuid
  ownerId      String        @map("owner_id") @db.Uuid
  name         String        @db.VarChar(160)
  description  String?
  category     String        @db.VarChar(80)
  condition    ItemCondition
  pricePerDay  Decimal       @map("price_per_day") @db.Decimal(12, 2)
  status       ItemStatus    @default(TERSEDIA)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  owner    User        @relation(fields: [ownerId], references: [id])
  photos   ItemPhoto[]
  bookings Booking[]

  @@index([ownerId])
  @@index([category])
  @@index([status])
  @@map("items")
}

model ItemPhoto {
  id        String  @id @default(uuid()) @db.Uuid
  itemId    String  @map("item_id") @db.Uuid
  url       String  @db.VarChar(255)
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(0) @map("sort_order")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("item_photos")
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  LATE
}

model Booking {
  id          String        @id @default(uuid()) @db.Uuid
  itemId      String        @map("item_id") @db.Uuid
  renterId    String        @map("renter_id") @db.Uuid
  startDate   DateTime      @map("start_date") @db.Date
  endDate     DateTime      @map("end_date") @db.Date
  status      BookingStatus @default(PENDING)
  totalPrice  Decimal       @map("total_price") @db.Decimal(12, 2)
  notes       String?
  requestedAt DateTime      @default(now()) @map("requested_at") @db.Timestamptz
  approvedAt  DateTime?     @map("approved_at") @db.Timestamptz
  rejectedAt  DateTime?     @map("rejected_at") @db.Timestamptz
  activatedAt DateTime?     @map("activated_at") @db.Timestamptz
  completedAt DateTime?     @map("completed_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  item   Item @relation(fields: [itemId], references: [id])
  renter User @relation(fields: [renterId], references: [id])

  @@index([itemId, status])
  @@index([renterId])
  @@map("bookings")
}

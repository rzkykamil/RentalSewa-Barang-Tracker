# Database
DATABASE_URL="postgresql://user:password@localhost:5432/rental_sewa_barang_tracker"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # generate: openssl rand -base64 32

# Email (reminder job worker) — SMTP atau Resend, isi salah satu sesuai provider yang dipakai
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="no-reply@example.com"
RESEND_API_KEY=""

# Upload foto barang (filesystem lokal)
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB="5"

# Internal job trigger (kalau reminder dipanggil via HTTP endpoint internal, bukan langsung dari worker process)
INTERNAL_JOB_SECRET=""

# App
NODE_ENV="development"
